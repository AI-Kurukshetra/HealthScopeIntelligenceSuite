NEXT_PUBLIC_APP_NAME=Health Scope Intelligence Suite
# Hosted Supabase project URL from the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Public anon key from the Supabase dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key from the Supabase dashboard; server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DEFAULT_TIMEZONE=America/Chicago

# Google sign-in uses the same public Supabase keys above.
# To enable it, configure Google under Supabase Dashboard -> Authentication -> Providers
# and add the Supabase redirect URL to your Google OAuth credentials.
