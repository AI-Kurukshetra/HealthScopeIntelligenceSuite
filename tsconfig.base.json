{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@healthscope/auth": [
        "packages/auth/src"
      ],
      "@healthscope/compliance": [
        "packages/compliance/src"
      ],
      "@healthscope/config": [
        "packages/config/src"
      ],
      "@healthscope/data-model": [
        "packages/data-model/src"
      ]
    }
  }
}

